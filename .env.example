# === ANTHROPIC (Claude AI) ===
ANTHROPIC_API_KEY=sk-ant-...

# === META (Instagram + WhatsApp Cloud API) ===
# Token de verificación para los webhooks (lo defines tú, mismo para ambos)
META_VERIFY_TOKEN=setter_ia_verify_token_secreto

# === BASE DE DATOS ===
# SQLite para desarrollo local (se crea automáticamente)
DATABASE_URL=sqlite:///./setter_ia.db
# PostgreSQL para producción (Render lo pone automáticamente)
# DATABASE_URL=postgresql://user:password@host:5432/setter_ia

# === PANEL DE ADMINISTRACIÓN ===
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
ADMIN_EMAIL=admin@tuagencia.com
ADMIN_PASSWORD=contraseña-segura

# NOTA: Las credenciales de Instagram y WhatsApp de cada cliente
# se configuran desde el panel de administración (/panel), no aquí.
